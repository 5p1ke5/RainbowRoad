if (gamepad_is_connected(0))
{
	dialogue = ["Use the direction pad to move around. Press A to jump!", "An '?' over your head means you can press 'UP' on the direction pad to interact with an object. Interact with the door to go to the next area."];
}
else
{
	dialogue = ["Use the arrow keys to move around. Press space to jump!", "An '?' over your head means you can press 'UP' on the keyboard to interact with an object. Interact with the door to go to the next area."];	
}

